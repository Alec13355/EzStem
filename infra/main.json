          "aadAdminName": {
            "value": "[parameters('aadAdminName')]"
          },
          "principalType": {
            "value": "[parameters('principalType')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.42.1.51946",
              "templateHash": "10514358026956276262"
            }
          },
          "parameters": {
            "environment": {
              "type": "string",
              "metadata": {
                "description": "Environment name"
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region"
              }
            },
            "appName": {
              "type": "string",
              "metadata": {
                "description": "Application name"
              }
            },
            "aadAdminObjectId": {
              "type": "string",
              "metadata": {
                "description": "Object ID of the AAD admin (deployer user or service principal)"
              }
            },
            "aadAdminName": {
              "type": "string",
              "metadata": {
                "description": "Display name of the AAD admin (deployer user or service principal)"
              }
            },
            "principalType": {
              "type": "string",
              "defaultValue": "Application",
              "metadata": {
                "description": "Principal type: Application for service principals, User for interactive users"
              }
            }
          },
          "variables": {
            "sqlServerName": "[format('{0}-sql', parameters('appName'))]",
            "sqlDatabaseName": "[format('{0}-db', parameters('appName'))]",
            "databaseTier": "[if(equals(parameters('environment'), 'prod'), 'Standard', 'Basic')]",
            "databaseSize": "[if(equals(parameters('environment'), 'prod'), 'S2', 'Basic')]"
          },
          "resources": [
            {
              "type": "Microsoft.Sql/servers",
              "apiVersion": "2023-05-01-preview",
              "name": "[variables('sqlServerName')]",
              "location": "[parameters('location')]",
              "properties": {
                "administrators": {
                  "login": "[parameters('aadAdminName')]",
                  "sid": "[parameters('aadAdminObjectId')]",
                  "tenantId": "[subscription().tenantId]",
                  "azureADOnlyAuthentication": true,
                  "principalType": "[parameters('principalType')]"
                },
                "version": "12.0",
                "publicNetworkAccess": "Enabled"
              }
            },
            {
              "type": "Microsoft.Sql/servers/databases",
              "apiVersion": "2023-05-01-preview",
              "name": "[format('{0}/{1}', variables('sqlServerName'), variables('sqlDatabaseName'))]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "[variables('databaseSize')]",
                "tier": "[variables('databaseTier')]"
              },
              "properties": {
                "collation": "SQL_Latin1_General_CP1_CI_AS",
                "maxSizeBytes": "[if(equals(parameters('environment'), 'prod'), json('268435456000'), json('2147483648'))]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
              ]
            },
            {
              "type": "Microsoft.Sql/servers/firewallRules",
              "apiVersion": "2023-05-01-preview",
              "name": "[format('{0}/{1}', variables('sqlServerName'), 'AllowAzureServices')]",
              "properties": {
                "startIpAddress": "0.0.0.0",
                "endIpAddress": "0.0.0.0"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
              ]
            }
          ],
          "outputs": {
            "sqlServerName": {
              "type": "string",
              "value": "[variables('sqlServerName')]"
            },
            "sqlDatabaseName": {
              "type": "string",
              "value": "[variables('sqlDatabaseName')]"
            },
            "connectionString": {
              "type": "string",
              "value": "[format('Server=tcp:{0},1433;Initial Catalog={1};Authentication=Active Directory Default;Encrypt=True;Connection Timeout=30;', reference(resourceId('Microsoft.Sql/servers', variables('sqlServerName')), '2023-05-01-preview').fullyQualifiedDomainName, variables('sqlDatabaseName'))]"
            }
          }
        }
      }
